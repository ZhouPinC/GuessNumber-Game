.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background-color: #f5f5f0;
  padding: 20rpx;
  box-sizing: border-box;
}

/* 未开始界面样式 */
.title {
  font-size: 48rpx;
  font-weight: bold;
  text-align: center;
  margin: 100rpx 0 50rpx;
  color: #333;
  font-family: "Microsoft YaHei", sans-serif;
}

.button-group {
  width: 80%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 30rpx;
  flex-grow: 1;
  justify-content: center;
}

.big-btn {
  margin: 20rpx 0 20rpx;
  width: 60%;
  height: 100rpx;
  font-size: 36rpx;
  line-height: 100rpx;
  border-radius: 50rpx;
  border: none;
  color: white;
  font-family: "Microsoft YaHei", sans-serif;
}

.start-btn {
  background-color: #4cae50;
}

.setting-btn {
  background-color: #2196f3;
}


.footer {
  text-align: center;
  color: #999;
  font-size: 24rpx;
  margin: 60rpx 0 20rpx;
}

/* 游戏界面样式 */
.game-header {
  background-color: white;
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.game-mode {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 10rpx;
}

.game-range {
  font-size: 28rpx;
  color: #666;
}

.game-area {
  display: contents;
  flex-direction: row;
  gap: 20rpx;
  flex-grow: 1;
}

.input-section {
  width: 80%;
  background-color: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 10rpx;
  display: flex;
  flex-direction: column;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.input-label {
  font-size: 32rpx;
  margin-bottom: 20rpx;
  color: #333;
}

.number-input {
  height: 80rpx;
  border: 2rpx solid #ddd;
  border-radius: 10rpx;
  padding: 0 20rpx;
  font-size: 30rpx;
  margin-bottom: 30rpx;
}

.button-group-game {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
}

.game-btn {
  font-size: 30rpx;
  border-radius: 10rpx;
  border: none;
  color: white;
}

.submit-btn {
  background-color: #4cae50;
}

.giveup-btn {
  background-color: #f44336;
}

.pause-btn {
  background-color: #ff9800;
}

.history-section {
  flex: 1;
  width: 82%;
  margin-top: 10rpx;
  background-color: white;
  border-radius: 20rpx;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.history-title {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 15rpx;
  color: #333;
  padding-bottom: 10rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.history-list {
  flex-grow: 1;
  height: 0;
}

.history-item {
  font-size: 28rpx;
  padding: 10rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
  display: flex;
  justify-content: space-between;
}

.history-num {
  color: #666;
}

.history-result {
  font-weight: bold;
}

.correct {
  color: #4cae50;
}

.high {
  color: #f44336;
}

.low {
  color: #ff9800;
}

.game-status {
  margin-top: 20rpx;
  padding: 15rpx;
  background-color: white;
  border-radius: 10rpx;
  font-size: 26rpx;
  color: #666;
  text-align: center;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

/* 弹窗样式 */
.modal-mask {
  position: fixed;
  z-index: 1000;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
}

.modal-dialog {
  position: fixed;
  z-index: 1001;
  width: 80%;
  max-width: 500rpx;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background-color: white;
  border-radius: 20rpx;
  overflow: hidden;
}

.modal-title {
  font-size: 34rpx;
  font-weight: bold;
  padding: 25rpx;
  text-align: center;
  border-bottom: 2rpx solid #f0f0f0;
  color: #333;
}

.modal-content {
  padding: 30rpx 25rpx;
}

.modal-footer {
  display: flex;
  flex-direction: row;
  border-top: 2rpx solid #f0f0f0;
}

.modal-btn {
  flex: 1;
  height: 90rpx;
  line-height: 90rpx;
  font-size: 32rpx;
  border-radius: 0;
  border: none;
  text-align: center;
}

.confirm-btn {
  color: #2196f3;
  background-color: white;
}

.cancel-btn {
  color: #666;
  background-color: #f5f5f5;
  border-right: 2rpx solid #f0f0f0;
}

/* 设置弹窗样式 */
.setting-item {
  margin-bottom: 30rpx;
  display: flex;
  flex-direction: column;
}

.setting-label {
  font-size: 28rpx;
  margin-bottom: 10rpx;
  color: #666;
}

.range-inputs {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 20rpx;
}

.range-input {
  flex: 1;
  height: 70rpx;
  border: 2rpx solid #ddd;
  border-radius: 10rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
}

.range-separator {
  font-size: 30rpx;
  color: #999;
}

.mode-options {
  display: flex;
  flex-direction: row;
  gap: 30rpx;
  padding: 10rpx 0;
}

.radio-label {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #333;
}

.attempts-input {
  width: 150rpx;
  height: 70rpx;
  border: 2rpx solid #ddd;
  border-radius: 10rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
}

/* 结果弹窗样式 */
.result-message {
  font-size: 30rpx;
  text-align: center;
  margin-bottom: 20rpx;
  color: #333;
}

.result-details {
  font-size: 28rpx;
  text-align: center;
  color: #666;
  margin-bottom: 10rpx;
}

.target-number {
  color: #f44336;
  font-weight: bold;
  font-size: 32rpx;
}

/* 暂停弹窗样式 */
.pause-info {
  font-size: 28rpx;
  margin-bottom: 15rpx;
  color: #666;
  text-align: center;
}